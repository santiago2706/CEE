{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "preview": {
      "dependsOn": ["build"]
    },
    "@cee/bot#dev": {
      "cache": false,
      "persistent": true,
      "env": [
        "GEMINI_API_KEY",
        "META_TOKEN",
        "PHONE_NUMBER_ID",
        "VERIFY_TOKEN",
        "SUPABASE_URL",
        "SUPABASE_KEY",
        "AI_PROVIDER",
        "PORT"
      ]
    }
  }
}
